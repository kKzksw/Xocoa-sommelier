# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Email/SMTP Configuration (for weekly reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
REPORT_EMAIL_FROM=noreply@xocoa-sommelier.com
REPORT_EMAIL_TO=julien@bonplein.fr

# Frontend Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# NextAuth Configuration
# For development: http://localhost:3000
# For production: https://xocoa-sommelier.com
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-secret-here

# Debug mode (production: false, development: true)
DEBUG=false

# Allow localhost in CORS (only for local testing, DO NOT enable in production)
# ALLOW_LOCALHOST=true
